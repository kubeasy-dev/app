{
  "$schema": "https://turborepo.dev/microfrontends/schema.json",
  "applications": {
    "@kubeasy/web": {
      "development": {
        "local": {
          "port": 3000
        }
      }
    },
    "@kubeasy/api": {
      "development": {
        "local": {
          "port": 3001
        }
      },
      "routing": [
        {
          "paths": ["/api/:path*"]
        }
      ]
    },
    "@kubeasy/admin": {
      "development": {
        "local": {
          "port": 3002
        }
      },
      "routing": [
        {
          "paths": ["/admin", "/admin/:path*"]
        }
      ]
    }
  }
}
