{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK",
    "buildCommand": "pnpm exec turbo run build --filter=@kubeasy/web",
    "watchPatterns": ["apps/web/**", "packages/**"]
  },
  "deploy": {
    "startCommand": "cd apps/web && node .output/server/index.mjs",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
